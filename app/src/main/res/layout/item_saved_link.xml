<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="8dp"
    android:layout_marginEnd="8dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp"
    android:background="@drawable/bg_glass_card"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="12dp">

    <!-- Thumbnail container (Loads OG Image or Platform placeholder icon) -->
    <androidx.cardview.widget.CardView
        android:layout_width="72dp"
        android:layout_height="72dp"
        app:cardCornerRadius="10dp"
        app:cardBackgroundColor="#121212"
        app:cardElevation="0dp"
        android:layout_marginEnd="14dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- High-Res OG Image loaded by Glide -->
            <ImageView
                android:id="@+id/link_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="@null" />

            <!-- Platform Default Icon Center overlay if image doesn't exist -->
            <ImageView
                android:id="@+id/platform_placeholder_logo"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_platform_chrome"
                android:contentDescription="@null" />

        </FrameLayout>
    </androidx.cardview.widget.CardView>

    <!-- Info Column Stack -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_vertical">

        <!-- Title -->
        <TextView
            android:id="@+id/link_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:text="Post Title placeholder"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginBottom="6dp"
            android:lineSpacingMultiplier="1.1" />

        <!-- Platform & Domain Header bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Little logo -->
            <ImageView
                android:id="@+id/platform_logo"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_platform_chrome"
                android:layout_marginEnd="6dp"
                android:contentDescription="@null" />

            <!-- Website Domain -->
            <TextView
                android:id="@+id/link_domain"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="domain.com"
                android:textColor="#90FFFFFF"
                android:textSize="11sp"
                android:fontFamily="sans-serif"
                android:singleLine="true"
                android:ellipsize="end" />

        </LinearLayout>

    </LinearLayout>

    <!-- Actions container -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginStart="6dp">

        <!-- Copy Action -->
        <ImageView
            android:id="@+id/copy_button"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="8dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_copy"
            android:contentDescription="Copy Link"
            android:clickable="true"
            android:focusable="true"/>

        <!-- Open Action (Arrow) -->
        <ImageView
            android:id="@+id/open_button"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="8dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_open"
            android:contentDescription="Open Link"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginStart="2dp"/>

        <!-- Delete Quick Action -->
        <ImageView
            android:id="@+id/delete_button"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="8dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_delete"
            android:contentDescription="Delete Link"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginStart="2dp" />
    </LinearLayout>

</LinearLayout>
